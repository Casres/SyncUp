# SyncUp Mobile — .env template.
# Copy to `.env` for local Expo dev.
#
#   cp .env.example .env
#
# Expo only bundles env vars prefixed with EXPO_PUBLIC_.

# ─── API ───────────────────────────────────────────────────────────────────
# Base URL of the SyncUp Fastify API. Defaults to http://localhost:3000 in
# _client.ts when unset.
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Clerk ─────────────────────────────────────────────────────────────────
# Required. Clerk frontend publishable key (Clerk Dashboard → API Keys →
# Publishable Key). The mobile app will fail to mount if this is unset.
# No default — every developer must paste their own key.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─── Dev token (deprecated — remove once Clerk is live) ────────────────────
# Pre-Clerk escape hatch: a session token issued by the Clerk dashboard, used
# as the Bearer token when no real Clerk session is available. Leave blank in
# normal development now that Clerk is wired up.
EXPO_PUBLIC_DEV_TOKEN=
