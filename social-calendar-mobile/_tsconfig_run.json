{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "jsx": "react-native",
    "outDir": "/tmp/_api_run",
    "resolveJsonModule": true
  },
  "include": [
    "_verify_api.ts",
    "src/api/**/*.ts",
    "src/mocks/**/*.ts",
    "../TYPES.ts",
    "../TOKENS.ts"
  ]
}
