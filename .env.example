# SyncUp — root .env template.
# Copy to `.env` for local docker compose dev.
#
#   cp .env.example .env
#
# docker-compose.yml automatically reads `.env` from this directory.

# ─── Postgres ──────────────────────────────────────────────────────────────
# The migration-owner role's password (POSTGRES_USER=syncup_migrate is
# fixed in docker-compose.yml). Used by the Prisma CLI.
POSTGRES_PASSWORD=syncup_migrate_dev

# Backend roles & connection strings — these are computed in
# docker-compose.yml from POSTGRES_PASSWORD. They're shown here for
# documentation only:
#   DATABASE_URL=postgresql://syncup_migrate:${POSTGRES_PASSWORD}@postgres:5432/syncup
#   DATABASE_URL_APP=postgresql://syncup_app:syncup_app_dev@postgres:5432/syncup
#
# Use DATABASE_URL_APP at runtime (Fastify) — it's the non-owner role and
# RLS policies apply. Use DATABASE_URL for `prisma migrate` only.
# See social-calendar-api/prisma/HANDOFF.md for the full contract.

# ─── Clerk ─────────────────────────────────────────────────────────────────
# Backend SDK key (Clerk Dashboard → API Keys → Secret Key).
CLERK_SECRET_KEY=sk_test_replace_me

# Webhook signing secret (Clerk Dashboard → Webhooks → Endpoint → Signing Secret).
CLERK_WEBHOOK_SECRET=whsec_replace_me
